    "UA marketing homepage",
    "homepage GIF/PNG/JPG assets",
    "dashboard demo graph",
    "remote font requests"
  ],
  "entrypoints": {
    "dashboard": "npm start",
    "api": "npm run api:start",
    "bootstrap": "./scripts/bootstrap.sh --install-deps",
    "validation": "npm run check"
  },
  "validation": {
    "sampleTests": "PASS",
    "knowledgeStore": "PASS",
    "taskFolderLayout": "PASS",
    "shellSyntax": "PASS",
    "javascriptSyntax": "PASS",
    "pythonSyntax": "PASS",
    "uaNetworkBootstrap": "NOT_RUN_IN_BUILD_ENVIRONMENT"
  }
}
