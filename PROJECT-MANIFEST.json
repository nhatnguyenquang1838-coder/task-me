{
  "project": "task-me",
  "version": "1.2.0",
  "purpose": "Render this repository knowledge graph with the UA dashboard and generate implementation plans with Task Architect.",
  "distribution": "source-only-slim",
  "ua": {
    "repository": "Egonex-AI/Understand-Anything",
    "commit": "6ae71878beb50226a1e4b7e2f52ac6468c86f74b",
    "runtimePath": "vendor/understand-anything",
    "committed": false,
    "bootstrap": "scripts/fetch-ua.sh"
  },
  "graphSource": ".ua/knowledge-graph.json",
